<!DOCTYPE html>
<html>
<head>
  <meta charset="UTF-8" />
</head>
<body style="font-family: Arial, sans-serif; background:#f4f6f8; padding:30px;">
  <div style="max-width:600px; background:#ffffff; margin:auto; padding:30px; border-radius:8px;">
    
    <h2 style="color:#2c3e50;">
      New Organization Account Request
    </h2>

    <p style="color:#555;">
      A new organization account has been submitted and is waiting for approval.
    </p>

    <hr/>

    <p><strong>Name:</strong> <%= applicantName %></p>
    <p><strong>Email:</strong> <%= applicantEmail %></p>
    <p><strong>Department:</strong> <%= department %></p>

    <br/>

    <p style="color:#888; font-size:12px;">
      This is an automated system notification.
    </p>

  </div>
</body>
</html>