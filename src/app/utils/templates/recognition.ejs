<!DOCTYPE html>
<html lang="en">

<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0">

  <title>Recognition Received</title>

  <style>
    body {
      margin: 0;
      padding: 0;
      background: #f5f7fb;
      font-family: Arial, Helvetica, sans-serif;
    }

    .container {
      max-width: 600px;
      margin: 30px auto;
      background: #ffffff;
      border-radius: 10px;
      overflow: hidden;
      box-shadow: 0 6px 20px rgba(0, 0, 0, 0.05);
      border: 1px solid #eee;
    }

    .header {
      background: #FF7321;
      color: white;
      text-align: center;
      padding: 25px;
      font-size: 22px;
      font-weight: bold;
    }

    .image {
      text-align: center;
      padding: 20px;
    }

    .image img {
      width: 100%;
    }

    .content {
      padding: 20px 30px;
      color: #333;
      font-size: 15px;
      line-height: 1.7;
    }

    .name {
      color: #FF7321;
      font-weight: bold;
    }

    .badges {
      margin: 15px 0;
    }

    .badge {
      display: inline-block;
      background: #f1f3f6;
      color: #444;
      padding: 6px 12px;
      border-radius: 20px;
      font-size: 13px;
      margin-right: 6px;
    }

    .message-box {
      background: #f8f9fc;
      padding: 15px;
      border-left: 4px solid #FF7321;
      border-radius: 6px;
      margin-top: 10px;
      font-style: italic;
    }

    .points {
      text-align: center;
      margin: 25px 0;
    }

    .points span {
      background: #FF7321;
      color: white;
      padding: 12px 18px;
      border-radius: 30px;
      font-size: 18px;
      font-weight: bold;
    }

    .footer {
      text-align: center;
      padding: 20px;
      font-size: 12px;
      color: #999;
      border-top: 1px solid #eee;
    }
  </style>
</head>

<body>

  <div class="container">

    <div class="header">
      You've Received a Recognition!
    </div>

    <div class="content">

      <p>
        Hi <span class="name">
          <%= receiverName %>
        </span>,
      </p>

      <p>
        <span class="name">
          <%= senderName %>
        </span> has recognized your outstanding contribution.
      </p>

      <!-- <div class="badges">
        <span class="badge">Category: <%= category %></span>
        <span class="badge">Value: <%= value %></span>
        <span class="badge">Tone: <%= tone %></span>
      </div> -->

      <div class="message-box">
        "<%= message %>"
      </div>

      <% if(image){ %>
        <div class="image">
          <img src="<%= image %>" alt="recognition">
        </div>
        <% } %>

          <div class="points">
            <span>⭐ <%= points %> Points Awarded</span>
          </div>



          <p style="text-align:center;">
            Keep up the amazing work and continue making an impact!
          </p>

    </div>

    <div class="footer">
      © <%= new Date().getFullYear() %> Greetely. All rights reserved.
    </div>

  </div>

</body>

</html>